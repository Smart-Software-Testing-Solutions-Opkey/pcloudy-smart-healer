{
  "name": "smarthealer-js",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript client for SmartHealer - intelligent web element locator resolution and healing",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist/index.js",
